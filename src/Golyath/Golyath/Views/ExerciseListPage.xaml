<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Golyath.Views.ExerciseListPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Golyath.ViewModels"
    xmlns:models="clr-namespace:Golyath.Models"
    x:DataType="vm:ExerciseListViewModel">

    <Shell.NavBarIsVisible>False</Shell.NavBarIsVisible>

    <Grid RowDefinitions="Auto,Auto,Auto,*">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Padding="24,52,24,8" Spacing="12">
            <Label Text="Exercises"
                   FontSize="32"
                   FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}" />

            <!-- Search bar -->
            <Border BackgroundColor="{StaticResource Surface2}"
                    Stroke="{StaticResource Border}"
                    StrokeThickness="1"
                    Padding="0">
                <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                <Grid ColumnDefinitions="Auto,*" Padding="12,0">
                    <Image Grid.Column="0" Source="ic_search.png"
                           HeightRequest="18" WidthRequest="18"
                           VerticalOptions="Center" />
                    <Entry Grid.Column="1"
                           Placeholder="Search exercises..."
                           Text="{Binding SearchText}"
                           BackgroundColor="Transparent"
                           TextColor="{StaticResource TextPrimary}"
                           PlaceholderColor="{StaticResource TextTertiary}"
                           HeightRequest="46" />
                </Grid>
            </Border>
        </VerticalStackLayout>

        <!-- Muscle group filter chips: 5 per row × 2 rows -->
        <FlexLayout Grid.Row="1"
                    Wrap="Wrap"
                    JustifyContent="SpaceEvenly"
                    BindableLayout.ItemsSource="{Binding MuscleGroupChips}"
                    Padding="14,4,14,4">
            <BindableLayout.ItemTemplate>
                <DataTemplate x:DataType="vm:MuscleGroupChipItem">
                    <Border BackgroundColor="{StaticResource Surface3}"
                            Stroke="{StaticResource Border}"
                            StrokeThickness="1"
                            Padding="10,5"
                            Margin="3,4">
                        <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ExerciseListViewModel}}, Path=SelectChipCommand}"
                                CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="BackgroundColor" Value="{StaticResource Accent}" />
                                <Setter Property="Stroke" Value="{StaticResource Accent}" />
                            </DataTrigger>
                        </Border.Triggers>
                        <Label Text="{Binding DisplayName}" FontSize="11" FontAttributes="Bold">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="TextColor" Value="#0A0A0A" />
                                </DataTrigger>
                                <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="False">
                                    <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </Border>
                </DataTemplate>
            </BindableLayout.ItemTemplate>
        </FlexLayout>

        <!-- Count label -->
        <Label Grid.Row="2"
               Margin="20,4,20,0"
               Style="{StaticResource CaptionLabel}"
               TextColor="{StaticResource TextTertiary}">
            <Label.FormattedText>
                <FormattedString>
                    <Span Text="{Binding Exercises.Count}" />
                    <Span Text=" exercises" />
                </FormattedString>
            </Label.FormattedText>
        </Label>

        <!-- Exercise list -->
        <CollectionView
            Grid.Row="3"
            ItemsSource="{Binding Exercises}"
            Margin="20,8,20,0"
            SelectionMode="None">
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8" Padding="0,40">
                    <Label Text="No exercises found" Style="{StaticResource SubheadingLabel}" HorizontalOptions="Center" />
                    <Label Text="Try a different search or filter" Style="{StaticResource CaptionLabel}" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Exercise">
                    <Border Style="{StaticResource Card}" Margin="0,4">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ExerciseListViewModel}}, Path=SelectExerciseCommand}"
                                CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="52,*,Auto" ColumnSpacing="14" VerticalOptions="Center">

                            <!-- Muscle group badge -->
                            <Border Grid.Column="0"
                                    BackgroundColor="{StaticResource Accent}"
                                    StrokeThickness="0"
                                    HeightRequest="48" WidthRequest="48">
                                <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                                <Label Text="{Binding MuscleGroupName, Converter={StaticResource MuscleGroupToAbbreviationConverter}}"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       TextColor="#0A0A0A"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>

                            <!-- Exercise info -->
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                                <Label Text="{Binding Name}" Style="{StaticResource SubheadingLabel}" />
                                <Label TextColor="{StaticResource TextTertiary}" FontSize="12">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding MuscleGroupName}" />
                                            <Span Text="  ·  " />
                                            <Span Text="{Binding IsCompound, Converter={StaticResource BoolToStringConverter}, ConverterParameter='Compound|Isolation'}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </VerticalStackLayout>

                            <!-- Chevron -->
                            <Label Grid.Column="2"
                                   Text="›"
                                   FontSize="22"
                                   TextColor="{StaticResource TextTertiary}"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>
