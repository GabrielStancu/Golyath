<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Golyath.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Golyath.ViewModels"
    x:DataType="vm:SettingsViewModel">

    <ScrollView>
        <VerticalStackLayout Padding="20,16" Spacing="16">

            <!-- Header -->
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                <Border Grid.Column="0"
                        BackgroundColor="{StaticResource Surface2}"
                        StrokeThickness="0"
                        HeightRequest="44" WidthRequest="44">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                    </Border.GestureRecognizers>
                    <Label Text="‹" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center"
                           TextColor="{StaticResource TextPrimary}" Padding="0,0,0,6" />
                </Border>
                <Label Grid.Column="1" Text="Settings" Style="{StaticResource HeadingLabel}" FontSize="24" VerticalOptions="Center" />
            </Grid>

            <Label Text="PREFERENCES" Style="{StaticResource SectionHeaderLabel}" />

            <!-- Units toggle -->
            <Border Style="{StaticResource Card}">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="4" VerticalOptions="Center">
                        <Label Text="Weight Unit" Style="{StaticResource SubheadingLabel}" />
                        <Label Text="{Binding UseKilograms, Converter={StaticResource BoolToStringConverter}, ConverterParameter='Kilograms (kg)|Pounds (lb)'}"
                               Style="{StaticResource CaptionLabel}" />
                    </VerticalStackLayout>
                    <Switch Grid.Column="1"
                            IsToggled="{Binding UseKilograms}"
                            OnColor="{StaticResource Accent}"
                            VerticalOptions="Center" />
                </Grid>
            </Border>

            <Label Text="ABOUT" Style="{StaticResource SectionHeaderLabel}" />

            <!-- App version -->
            <Border Style="{StaticResource Card}">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0" Text="Version" Style="{StaticResource SubheadingLabel}" VerticalOptions="Center" />
                    <Label Grid.Column="1" Text="{Binding AppVersion}" Style="{StaticResource CaptionLabel}" VerticalOptions="Center" />
                </Grid>
            </Border>

            <!-- App name -->
            <Border Style="{StaticResource Card}">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0" Text="App" Style="{StaticResource SubheadingLabel}" VerticalOptions="Center" />
                    <Label Grid.Column="1" Text="Golyath" Style="{StaticResource AccentLabel}" VerticalOptions="Center" />
                </Grid>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
