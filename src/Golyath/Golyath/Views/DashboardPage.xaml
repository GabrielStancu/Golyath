<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Golyath.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Golyath.ViewModels"
    xmlns:charts="clr-namespace:Golyath.Charts"
    x:DataType="vm:DashboardViewModel">

    <Shell.NavBarIsVisible>False</Shell.NavBarIsVisible>

    <ScrollView>
        <VerticalStackLayout Padding="24,52,24,24" Spacing="0">

            <!-- ===== Header row: greeting + settings ===== -->
            <Grid ColumnDefinitions="*,44" Margin="0,0,0,28">
                <VerticalStackLayout Grid.Column="0" Spacing="2">
                    <Label Text="{Binding Greeting}"
                           FontSize="13"
                           TextColor="{StaticResource TextTertiary}"
                           FontAttributes="Bold"
                           CharacterSpacing="1.5" />
                    <Label Text="{Binding DateLabel}"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" />
                </VerticalStackLayout>
                <Border Grid.Column="1"
                        BackgroundColor="{StaticResource Surface2}"
                        StrokeThickness="0"
                        HeightRequest="44" WidthRequest="44"
                        HorizontalOptions="End"
                        VerticalOptions="Start">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToSettingsCommand}" />
                    </Border.GestureRecognizers>
                    <Image Source="ic_tab_analytics.png"
                           HeightRequest="20" WidthRequest="20"
                           HorizontalOptions="Center" VerticalOptions="Center"
                           Opacity="0.6" />
                </Border>
            </Grid>

            <!-- ===== Primary stats strip ===== -->
            <Grid ColumnDefinitions="*,1,*,1,*" Margin="0,0,0,24">
                <!-- Workouts -->
                <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="4" Margin="6,0">
                    <Label Text="{Binding WorkoutsThisWeek}"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Accent}"
                           HorizontalOptions="Center" />
                    <Label Text="Sessions"
                           FontSize="11"
                           TextColor="{StaticResource TextTertiary}"
                           FontAttributes="Bold"
                           CharacterSpacing="1"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>

                <!-- Divider -->
                <BoxView Grid.Column="1" BackgroundColor="{StaticResource Border}"
                         WidthRequest="1" HeightRequest="40" VerticalOptions="Center" />

                <!-- Volume -->
                <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="4" Margin="6,0">
                    <Label Text="{Binding TotalVolumeThisWeek}"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}"
                           HorizontalOptions="Center" />
                    <Label Text="Volume"
                           FontSize="11"
                           TextColor="{StaticResource TextTertiary}"
                           FontAttributes="Bold"
                           CharacterSpacing="1"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>

                <!-- Divider -->
                <BoxView Grid.Column="3" BackgroundColor="{StaticResource Border}"
                         WidthRequest="1" HeightRequest="40" VerticalOptions="Center" />

                <!-- Avg duration -->
                <VerticalStackLayout Grid.Column="4" HorizontalOptions="Center" Spacing="4" Margin="6,0">
                    <Label Text="{Binding AvgDuration}"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}"
                           HorizontalOptions="Center" />
                    <Label Text="Avg Time"
                           FontSize="11"
                           TextColor="{StaticResource TextTertiary}"
                           FontAttributes="Bold"
                           CharacterSpacing="1"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Grid>

            <!-- ===== Weekly Volume Chart card ===== -->
            <Border BackgroundColor="{StaticResource Surface1}"
                    StrokeThickness="0"
                    Padding="16,20,16,12"
                    Margin="0,0,0,20">
                <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                <VerticalStackLayout Spacing="16">
                    <!-- Card header -->
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="WEEKLY VOLUME"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   CharacterSpacing="1.5"
                                   TextColor="{StaticResource TextTertiary}" />
                            <Label Text="{Binding TotalVolumeThisWeek}"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}" />
                        </VerticalStackLayout>
                        <Border Grid.Column="1"
                                BackgroundColor="{StaticResource Surface3}"
                                StrokeThickness="0"
                                Padding="10,6"
                                VerticalOptions="Start">
                            <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                            <Label Text="This week"
                                   FontSize="11"
                                   TextColor="{StaticResource Accent}" />
                        </Border>
                    </Grid>

                    <!-- Bar chart -->
                    <GraphicsView x:Name="VolumeChartView"
                                  Drawable="{Binding VolumeChart}"
                                  HeightRequest="148"
                                  HorizontalOptions="Fill" />
                </VerticalStackLayout>
            </Border>

            <!-- ===== Recent workouts ===== -->
            <Label Text="RECENT WORKOUTS"
                   FontSize="11"
                   FontAttributes="Bold"
                   CharacterSpacing="1.5"
                   TextColor="{StaticResource TextTertiary}"
                   Margin="0,0,0,12" />

            <!-- Busy indicator -->
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               HorizontalOptions="Center"
                               Margin="0,8" />

            <!-- Recent workout items -->
            <VerticalStackLayout BindableLayout.ItemsSource="{Binding RecentWorkouts}" Spacing="10">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="vm:RecentWorkoutItem">
                        <Border BackgroundColor="{StaticResource Surface1}"
                                StrokeThickness="0"
                                Padding="16,14">
                            <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">

                                <!-- Day badge -->
                                <Border Grid.Column="0"
                                        BackgroundColor="{StaticResource Surface3}"
                                        StrokeThickness="0"
                                        HeightRequest="48" WidthRequest="48">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="0">
                                        <Label Text="{Binding DayLabel}"
                                               FontSize="11"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource Accent}"
                                               HorizontalOptions="Center" />
                                        <Label Text="{Binding DateLabel}"
                                               FontSize="10"
                                               TextColor="{StaticResource TextTertiary}"
                                               HorizontalOptions="Center" />
                                    </VerticalStackLayout>
                                </Border>

                                <!-- Workout info -->
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                                    <Label Text="{Binding VolumeLabel}"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource TextPrimary}" />
                                    <Label TextColor="{StaticResource TextTertiary}" FontSize="12">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{Binding DurationLabel}" />
                                                <Span Text="    " />
                                                <Span Text="{Binding ExerciseCount}" />
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                </VerticalStackLayout>

                                <!-- Chevron -->
                                <Label Grid.Column="2"
                                       Text=""
                                       FontSize="20"
                                       TextColor="{StaticResource TextTertiary}"
                                       VerticalOptions="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <!-- Empty state when no real workouts yet -->
            <Border BackgroundColor="{StaticResource Surface1}"
                    StrokeThickness="0"
                    Padding="20,24"
                    IsVisible="{Binding HasNoLastWorkout}"
                    Margin="0,4">
                <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Label Text="No workouts yet"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextSecondary}"
                           HorizontalOptions="Center" />
                    <Label Text="Head to the Workout tab to start your first session"
                           FontSize="13"
                           TextColor="{StaticResource TextTertiary}"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
