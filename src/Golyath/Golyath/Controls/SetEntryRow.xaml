<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="Golyath.Controls.SetEntryRow"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="this">

    <Border Style="{StaticResource Card}" Padding="12,10" Margin="0,4">
        <Grid ColumnDefinitions="32,*,*,*,48" ColumnSpacing="8">

            <!-- Set number badge -->
            <Border Grid.Column="0"
                    BackgroundColor="{StaticResource Surface3}"
                    StrokeThickness="0"
                    HeightRequest="32" WidthRequest="32">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Label Text="{Binding SetNumber, Source={x:Reference this}}"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       Style="{StaticResource CaptionLabel}"
                       TextColor="{StaticResource TextSecondary}" />
            </Border>

            <!-- Weight entry -->
            <VerticalStackLayout Grid.Column="1" Spacing="2">
                <Label Text="KG" Style="{StaticResource CaptionLabel}" TextColor="{StaticResource TextTertiary}" />
                <Entry Text="{Binding Weight, Source={x:Reference this}, Mode=TwoWay}"
                       Keyboard="Numeric"
                       Placeholder="0"
                       HorizontalTextAlignment="Center"
                       BackgroundColor="{StaticResource Surface3}"
                       HeightRequest="40" />
            </VerticalStackLayout>

            <!-- Reps entry -->
            <VerticalStackLayout Grid.Column="2" Spacing="2">
                <Label Text="REPS" Style="{StaticResource CaptionLabel}" TextColor="{StaticResource TextTertiary}" />
                <Entry Text="{Binding Reps, Source={x:Reference this}, Mode=TwoWay}"
                       Keyboard="Numeric"
                       Placeholder="0"
                       HorizontalTextAlignment="Center"
                       BackgroundColor="{StaticResource Surface3}"
                       HeightRequest="40" />
            </VerticalStackLayout>

            <!-- Warmup toggle -->
            <VerticalStackLayout Grid.Column="3" Spacing="2" HorizontalOptions="Center">
                <Label Text="WARM" Style="{StaticResource CaptionLabel}" TextColor="{StaticResource TextTertiary}" HorizontalOptions="Center" />
                <CheckBox IsChecked="{Binding IsWarmup, Source={x:Reference this}, Mode=TwoWay}"
                          Color="{StaticResource Accent}"
                          HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- Complete checkmark -->
            <Border Grid.Column="4"
                    BackgroundColor="{Binding IsComplete, Source={x:Reference this}, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#F5C518|#282828'}"
                    StrokeThickness="0"
                    HeightRequest="40" WidthRequest="40"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ToggleCompleteCommand, Source={x:Reference this}}" />
                </Border.GestureRecognizers>
                <Label Text="✓"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       FontSize="18"
                       TextColor="{Binding IsComplete, Source={x:Reference this}, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#0A0A0A|#5A5A5A'}" />
            </Border>

        </Grid>
    </Border>

</ContentView>
