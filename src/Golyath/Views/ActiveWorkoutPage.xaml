<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Golyath.Views.ActiveWorkoutPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Golyath.ViewModels"
    xmlns:models="clr-namespace:Golyath.Models"
    x:DataType="vm:ActiveWorkoutViewModel">

    <Shell.NavBarIsVisible>False</Shell.NavBarIsVisible>

    <Grid>

        <!-- ===== IDLE STATE  shown when no session is active ===== -->
        <ScrollView IsVisible="{Binding IsSessionIdle}">
            <VerticalStackLayout Padding="24,64,24,40" Spacing="0">

                <!-- Page title -->
                <Label Text="Workout"
                       FontSize="32"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}"
                       Margin="0,0,0,8" />
                <Label Text="Start a session to log your lifts"
                       FontSize="14"
                       TextColor="{StaticResource TextTertiary}"
                       Margin="0,0,0,32" />

                <!-- Big Freeform Start CTA card -->
                <Border BackgroundColor="{StaticResource Accent}"
                        StrokeThickness="0"
                        Padding="0"
                        Margin="0,0,0,24">
                    <Border.StrokeShape><RoundRectangle CornerRadius="24" /></Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding StartWorkoutCommand}" />
                    </Border.GestureRecognizers>
                    <Grid RowDefinitions="Auto,Auto,Auto" Padding="28,28" RowSpacing="10">
                        <Border Grid.Row="0"
                                BackgroundColor="#33000000"
                                StrokeThickness="0"
                                HeightRequest="56" WidthRequest="56">
                            <Border.StrokeShape><RoundRectangle CornerRadius="18" /></Border.StrokeShape>
                            <Label Text="▶"
                                   FontSize="22"
                                   TextColor="#0A0A0A"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                        <Label Grid.Row="1"
                               Text="Start Freeform Workout"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="#0A0A0A" />
                        <Label Grid.Row="2"
                               Text="Add any exercises on the fly"
                               FontSize="13"
                               TextColor="#44000000" />
                    </Grid>
                </Border>

                <!-- Separator -->
                <Grid ColumnDefinitions="*,Auto,*" Margin="0,0,0,24" ColumnSpacing="12">
                    <BoxView Grid.Column="0" BackgroundColor="{StaticResource Border}"
                             HeightRequest="1" VerticalOptions="Center" />
                    <Label Grid.Column="1" Text="OR FROM A TEMPLATE"
                           FontSize="11" FontAttributes="Bold" CharacterSpacing="1.5"
                           TextColor="{StaticResource TextTertiary}" />
                    <BoxView Grid.Column="2" BackgroundColor="{StaticResource Border}"
                             HeightRequest="1" VerticalOptions="Center" />
                </Grid>

                <!-- Template cards -->
                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Templates}" Spacing="10">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:WorkoutTemplate">
                            <Border BackgroundColor="{StaticResource Surface1}"
                                    StrokeThickness="0" Padding="0">
                                <Border.StrokeShape><RoundRectangle CornerRadius="18" /></Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ActiveWorkoutViewModel}}, Path=StartWorkoutFromTemplateCommand}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Grid ColumnDefinitions="8,*,Auto" ColumnSpacing="14" Padding="0,16,16,16">
                                    <!-- Color strip -->
                                    <BoxView Grid.Column="0"
                                             WidthRequest="5"
                                             CornerRadius="3"
                                             VerticalOptions="Fill"
                                             BackgroundColor="{Binding Color}" />
                                    <VerticalStackLayout Grid.Column="1" Spacing="3">
                                        <Label Text="{Binding Name}"
                                               FontSize="15" FontAttributes="Bold"
                                               TextColor="{StaticResource TextPrimary}" />
                                        <Label Text="{Binding Description}"
                                               FontSize="12" TextColor="{StaticResource TextTertiary}"
                                               LineBreakMode="TailTruncation"
                                               IsVisible="{Binding Description, Converter={StaticResource IsNotNullOrEmptyConverter}}" />
                                    </VerticalStackLayout>
                                    <Label Grid.Column="2"
                                           Text="›" FontSize="22"
                                           TextColor="{StaticResource TextTertiary}"
                                           VerticalOptions="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

                <!-- Manage templates link -->
                <Border BackgroundColor="{StaticResource Surface1}"
                        StrokeThickness="1" Stroke="{StaticResource Border}"
                        Padding="16,14" Margin="0,10,0,0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToTemplatesCommand}" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Label Grid.Column="0"
                               Text="Manage Templates"
                               FontSize="14" FontAttributes="Bold"
                               TextColor="{StaticResource TextSecondary}"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="›" FontSize="18"
                               TextColor="{StaticResource TextTertiary}" VerticalOptions="Center" />
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ===== ACTIVE STATE  shown during a session ===== -->
        <Grid RowDefinitions="Auto,*" IsVisible="{Binding IsSessionActive}">

            <!-- Active header: timer + Finish -->
            <Border Grid.Row="0"
                    BackgroundColor="{StaticResource Surface1}"
                    StrokeThickness="0"
                    Padding="24,52,24,16">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label Text="IN SESSION"
                               FontSize="11"
                               FontAttributes="Bold"
                               CharacterSpacing="1.5"
                               TextColor="{StaticResource Accent}" />
                        <Label Text="{Binding ElapsedTime}"
                               FontSize="40"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />
                    </VerticalStackLayout>

                    <Button Grid.Column="1"
                            Text="Finish"
                            Command="{Binding FinishWorkoutCommand}"
                            BackgroundColor="{StaticResource Danger}"
                            TextColor="White"
                            FontAttributes="Bold"
                            FontSize="16"
                            CornerRadius="14"
                            HeightRequest="50"
                            Padding="20,0"
                            VerticalOptions="End" />
                </Grid>
            </Border>

            <!-- Exercise list -->
            <CollectionView
                Grid.Row="1"
                ItemsSource="{Binding ExerciseItems}"
                Margin="0,0">
                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center"
                                         Spacing="12" Padding="40">
                        <Label Text="No exercises yet"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextSecondary}"
                               HorizontalOptions="Center" />
                        <Label Text="Tap the + button below to add your first exercise"
                               FontSize="14"
                               TextColor="{StaticResource TextTertiary}"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:ActiveExerciseItem">
                        <VerticalStackLayout Padding="20,8" Spacing="4">

                            <!-- Exercise name + Add Set -->
                            <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                                <Label Grid.Column="0"
                                       Text="{Binding Exercise.Name}"
                                       Style="{StaticResource SubheadingLabel}"
                                       FontAttributes="Bold" />
                                <Button Grid.Column="1"
                                        Text="+ Set"
                                        Style="{StaticResource GhostButton}"
                                        FontSize="13"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ActiveWorkoutViewModel}}, Path=AddSetCommand}"
                                        CommandParameter="{Binding .}" />
                            </Grid>

                            <!-- Column headers -->
                            <Grid ColumnDefinitions="32,*,*,60,*,48" ColumnSpacing="6" Padding="8,0">
                                <Label Grid.Column="0" Text="#" Style="{StaticResource CaptionLabel}" HorizontalOptions="Center" />
                                <Label Grid.Column="1" Text="KG" Style="{StaticResource CaptionLabel}" HorizontalOptions="Center" />
                                <Label Grid.Column="2" Text="REPS" Style="{StaticResource CaptionLabel}" HorizontalOptions="Center" />
                                <Label Grid.Column="3" Text="TEMPO" Style="{StaticResource CaptionLabel}" HorizontalOptions="Center" />
                                <Label Grid.Column="4" Text="WARM" Style="{StaticResource CaptionLabel}" HorizontalOptions="Center" />
                                <Label Grid.Column="5" Text="✓" Style="{StaticResource CaptionLabel}" HorizontalOptions="Center" />
                            </Grid>

                            <!-- Sets -->
                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Sets}" Spacing="0">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:WorkoutSet">
                                        <Border Style="{StaticResource Card}" Margin="0,3" Padding="8,8">
                                            <Grid ColumnDefinitions="32,*,*,60,*,48" ColumnSpacing="6">

                                                <!-- Set number badge -->
                                                <Border Grid.Column="0"
                                                        BackgroundColor="{StaticResource Surface3}"
                                                        StrokeThickness="0"
                                                        HeightRequest="32" WidthRequest="32">
                                                    <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                                                    <Label Text="{Binding SetNumber}"
                                                           HorizontalOptions="Center" VerticalOptions="Center"
                                                           Style="{StaticResource CaptionLabel}"
                                                           TextColor="{StaticResource Accent}" />
                                                </Border>

                                                <!-- Weight -->
                                                <Border Grid.Column="1" BackgroundColor="{StaticResource Surface3}"
                                                        StrokeThickness="0" HeightRequest="36">
                                                    <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                                                    <Entry Text="{Binding Weight, Mode=TwoWay}" Keyboard="Numeric"
                                                           Placeholder="0" HorizontalTextAlignment="Center"
                                                           BackgroundColor="Transparent" FontSize="14" />
                                                </Border>

                                                <!-- Reps -->
                                                <Border Grid.Column="2" BackgroundColor="{StaticResource Surface3}"
                                                        StrokeThickness="0" HeightRequest="36">
                                                    <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                                                    <Entry Text="{Binding Reps, Mode=TwoWay}" Keyboard="Numeric"
                                                           Placeholder="0" HorizontalTextAlignment="Center"
                                                           BackgroundColor="Transparent" FontSize="14" />
                                                </Border>

                                                <!-- Tempo -->
                                                <Border Grid.Column="3" BackgroundColor="{StaticResource Surface3}"
                                                        StrokeThickness="0" HeightRequest="36">
                                                    <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                                                    <Entry Text="{Binding Tempo, Mode=TwoWay}"
                                                           Placeholder="3-1-2-0"
                                                           HorizontalTextAlignment="Center"
                                                           BackgroundColor="Transparent" FontSize="11"
                                                           TextColor="{StaticResource TextSecondary}" />
                                                </Border>

                                                <!-- Warmup -->
                                                <CheckBox Grid.Column="4" IsChecked="{Binding IsWarmup, Mode=TwoWay}"
                                                          Color="{StaticResource Accent}"
                                                          HorizontalOptions="Center" VerticalOptions="Center" />

                                                <!-- Complete -->
                                                <Border Grid.Column="5" BackgroundColor="{StaticResource Surface3}"
                                                        StrokeThickness="0" HeightRequest="36" WidthRequest="36"
                                                        HorizontalOptions="Center" VerticalOptions="Center">
                                                    <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                                                    <Border.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ActiveWorkoutViewModel}}, Path=CompleteSetCommand}"
                                                            CommandParameter="{Binding .}" />
                                                    </Border.GestureRecognizers>
                                                    <Label Text="✓" HorizontalOptions="Center" VerticalOptions="Center"
                                                           FontSize="14" TextColor="{StaticResource Success}" />
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>

                            <BoxView Style="{StaticResource Divider}" Margin="0,8,0,0" />
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </Grid>

        <!-- ===== FAB: + Exercise  shown during active session ===== -->
        <Button Text="+"
                FontSize="30"
                FontAttributes="Bold"
                TextColor="#0A0A0A"
                BackgroundColor="{StaticResource Accent}"
                CornerRadius="20"
                HeightRequest="60"
                WidthRequest="60"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="0,0,24,32"
                IsVisible="{Binding IsSessionActive}"
                Command="{Binding ShowExercisePickerCommand}" />

        <!-- ===== Exercise Picker Overlay ===== -->
        <Grid BackgroundColor="#CC000000"
              IsVisible="{Binding IsPickerVisible}">
            <Border BackgroundColor="{StaticResource Surface2}"
                    StrokeThickness="0"
                    VerticalOptions="End">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20,20,0,0" />
                </Border.StrokeShape>
                <Grid RowDefinitions="20,Auto,*" HeightRequest="520">
                    <!-- Drag handle -->
                    <BoxView Grid.Row="0" HeightRequest="4" WidthRequest="40"
                             BackgroundColor="{StaticResource Border}"
                             HorizontalOptions="Center" VerticalOptions="Center" />
                    <!-- Search -->
                    <SearchBar Grid.Row="1" Placeholder="Search exercises..."
                               Text="{Binding ExercisePickerSearch}" Margin="16,4" />
                    <!-- Exercise list -->
                    <CollectionView Grid.Row="2" ItemsSource="{Binding FilteredPickerExercises}" Margin="16,4">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Exercise">
                                <Border Style="{StaticResource Card}" Margin="0,4">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ActiveWorkoutViewModel}}, Path=AddExerciseCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <Label Text="{Binding Name}" Style="{StaticResource SubheadingLabel}" />
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </Border>
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding HideExercisePickerCommand}" />
            </Grid.GestureRecognizers>
        </Grid>

    </Grid>

</ContentPage>
