<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Golyath.Views.TemplateListPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Golyath.ViewModels"
    xmlns:models="clr-namespace:Golyath.Models"
    x:DataType="vm:TemplateListViewModel">

    <Shell.NavBarIsVisible>False</Shell.NavBarIsVisible>

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="44,*" Padding="20,52,20,16" ColumnSpacing="12">
            <Border Grid.Column="0"
                    BackgroundColor="{StaticResource Surface2}"
                    StrokeThickness="0"
                    HeightRequest="44" WidthRequest="44"
                    VerticalOptions="Start">
                <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                </Border.GestureRecognizers>
                <Label Text="‹" FontSize="22" FontAttributes="Bold"
                       HorizontalOptions="Center" VerticalOptions="Center"
                       TextColor="{StaticResource TextPrimary}" />
            </Border>
            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                <Label Text="My Templates"
                       FontSize="24" FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}" />
                <Label Text="Tap to edit · Long-press to delete"
                       FontSize="12" TextColor="{StaticResource TextTertiary}" />
            </VerticalStackLayout>
        </Grid>

        <!-- List -->
        <RefreshView Grid.Row="1"
                     Command="{Binding LoadCommand}"
                     IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Templates}" Margin="20,0,20,80">
                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center"
                                         Spacing="16" Padding="40" Margin="0,60,0,0">
                        <Label Text="📋" FontSize="48" HorizontalOptions="Center" />
                        <Label Text="No templates yet"
                               FontSize="18" FontAttributes="Bold"
                               TextColor="{StaticResource TextSecondary}"
                               HorizontalOptions="Center" />
                        <Label Text="Tap + to create your first workout template"
                               FontSize="13" TextColor="{StaticResource TextTertiary}"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:WorkoutTemplate">
                        <Border Style="{StaticResource Card}" Margin="0,6">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TemplateListViewModel}}, Path=EditTemplateCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="12,*,Auto" ColumnSpacing="14">
                                <!-- Color accent strip -->
                                <BoxView Grid.Column="0"
                                         WidthRequest="4"
                                         CornerRadius="2"
                                         VerticalOptions="Fill"
                                         BackgroundColor="{Binding Color}" />

                                <VerticalStackLayout Grid.Column="1" Spacing="4">
                                    <Label Text="{Binding Name}"
                                           FontSize="16" FontAttributes="Bold"
                                           TextColor="{StaticResource TextPrimary}" />
                                    <Label Text="{Binding Description}"
                                           FontSize="12" TextColor="{StaticResource TextTertiary}"
                                           LineBreakMode="TailTruncation"
                                           IsVisible="{Binding Description, Converter={StaticResource IsNotNullOrEmptyConverter}}" />
                                    <Label FontSize="11" TextColor="{StaticResource TextTertiary}">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="Last used: " />
                                                <Span Text="{Binding LastUsedAt, StringFormat='{0:MMM d, yyyy}', FallbackValue='Never'}" />
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                </VerticalStackLayout>

                                <Border Grid.Column="2"
                                        BackgroundColor="{StaticResource Surface3}"
                                        StrokeThickness="0"
                                        HeightRequest="36" WidthRequest="36"
                                        VerticalOptions="Center">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="11" /></Border.StrokeShape>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TemplateListViewModel}}, Path=DeleteTemplateCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <Label Text="✕" FontSize="14"
                                           TextColor="{StaticResource TextTertiary}"
                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!-- FAB: + New Template -->
        <Button Grid.Row="1"
                Text="+ New Template"
                BackgroundColor="{StaticResource Accent}"
                TextColor="#0A0A0A"
                FontAttributes="Bold"
                FontSize="15"
                CornerRadius="20"
                HeightRequest="52"
                HorizontalOptions="Center"
                VerticalOptions="End"
                Margin="0,0,0,28"
                Padding="24,0"
                Command="{Binding CreateTemplateCommand}" />
    </Grid>

</ContentPage>
