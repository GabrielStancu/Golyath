<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Golyath.Views.AnalyticsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Golyath.ViewModels"
    x:DataType="vm:AnalyticsViewModel">

    <Shell.NavBarIsVisible>False</Shell.NavBarIsVisible>

    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="16">
        <Label Text="📊" FontSize="64" HorizontalOptions="Center" />
        <Label Text="Analytics"
               FontSize="32"
               FontAttributes="Bold"
               TextColor="{StaticResource TextPrimary}"
               HorizontalOptions="Center" />
        <Label Text="{Binding PlaceholderMessage}"
               Style="{StaticResource SubheadingLabel}"
               TextColor="{StaticResource TextSecondary}"
               HorizontalOptions="Center"
               HorizontalTextAlignment="Center" />
    </VerticalStackLayout>

</ContentPage>
