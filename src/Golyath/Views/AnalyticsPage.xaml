<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Golyath.Views.AnalyticsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Golyath.ViewModels"
    xmlns:charts="clr-namespace:Golyath.Charts"
    xmlns:services="clr-namespace:Golyath.Services"
    x:DataType="vm:AnalyticsViewModel">

    <Shell.NavBarIsVisible>False</Shell.NavBarIsVisible>

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- ── Header ── -->
        <VerticalStackLayout Grid.Row="0" Padding="24,56,24,0" Spacing="4">
            <Label Text="Analytics"
                   FontSize="32" FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}" />
            <Label Text="Track your progress over time"
                   FontSize="13" TextColor="{StaticResource TextTertiary}" />
        </VerticalStackLayout>

        <!-- ── Tab bar ── -->
        <Border Grid.Row="1"
                BackgroundColor="{StaticResource Surface1}"
                StrokeThickness="0"
                Padding="4" Margin="20,16,20,0">
            <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="4">
                <!-- Volume tab -->
                <Border Grid.Column="0" Padding="0,10" StrokeThickness="0"
                        BackgroundColor="{Binding IsVolumeTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#F5C518|#00000000'}">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetVolumeTabCommand}" />
                    </Border.GestureRecognizers>
                    <Label Text="Volume" HorizontalOptions="Center" FontSize="13" FontAttributes="Bold"
                           TextColor="{Binding IsVolumeTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#0A0A0A|#888888'}" />
                </Border>
                <!-- Muscles tab -->
                <Border Grid.Column="1" Padding="0,10" StrokeThickness="0"
                        BackgroundColor="{Binding IsMusclesTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#F5C518|#00000000'}">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetMusclesTabCommand}" />
                    </Border.GestureRecognizers>
                    <Label Text="Muscles" HorizontalOptions="Center" FontSize="13" FontAttributes="Bold"
                           TextColor="{Binding IsMusclesTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#0A0A0A|#888888'}" />
                </Border>
                <!-- Frequency tab -->
                <Border Grid.Column="2" Padding="0,10" StrokeThickness="0"
                        BackgroundColor="{Binding IsFrequencyTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#F5C518|#00000000'}">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetFrequencyTabCommand}" />
                    </Border.GestureRecognizers>
                    <Label Text="Frequency" HorizontalOptions="Center" FontSize="13" FontAttributes="Bold"
                           TextColor="{Binding IsFrequencyTab, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#0A0A0A|#888888'}" />
                </Border>
            </Grid>
        </Border>

        <!-- ── Content panels ── -->
        <Grid Grid.Row="2">

            <!-- VOLUME TAB -->
            <ScrollView IsVisible="{Binding IsVolumeTab}">
                <VerticalStackLayout Padding="20,16" Spacing="16">

                    <!-- Section header -->
                    <Label Text="THIS WEEK" FontSize="11" FontAttributes="Bold"
                           CharacterSpacing="1.5" TextColor="{StaticResource TextTertiary}" />

                    <!-- Chart card -->
                    <Border BackgroundColor="{StaticResource Surface1}"
                            StrokeThickness="0" Padding="16">
                        <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                        <VerticalStackLayout Spacing="12">
                            <GraphicsView Drawable="{Binding VolumeChart}"
                                          HeightRequest="160" />
                            <!-- Stats row -->
                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                                <Border Grid.Column="0" BackgroundColor="{StaticResource Surface2}"
                                        StrokeThickness="0" Padding="10,12">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="{Binding TotalWeekVolume}"
                                               FontSize="18" FontAttributes="Bold"
                                               TextColor="{StaticResource Accent}"
                                               HorizontalOptions="Center" />
                                        <Label Text="Total" FontSize="10"
                                               TextColor="{StaticResource TextTertiary}"
                                               HorizontalOptions="Center" />
                                    </VerticalStackLayout>
                                </Border>
                                <Border Grid.Column="1" BackgroundColor="{StaticResource Surface2}"
                                        StrokeThickness="0" Padding="10,12">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="{Binding PeakDayLabel}"
                                               FontSize="13" FontAttributes="Bold"
                                               TextColor="{StaticResource TextPrimary}"
                                               HorizontalOptions="Center"
                                               HorizontalTextAlignment="Center" />
                                        <Label Text="Peak day" FontSize="10"
                                               TextColor="{StaticResource TextTertiary}"
                                               HorizontalOptions="Center" />
                                    </VerticalStackLayout>
                                </Border>
                                <Border Grid.Column="2" BackgroundColor="{StaticResource Surface2}"
                                        StrokeThickness="0" Padding="10,12">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="{Binding ActiveDaysLabel}"
                                               FontSize="13" FontAttributes="Bold"
                                               TextColor="{StaticResource TextPrimary}"
                                               HorizontalOptions="Center" />
                                        <Label Text="Active" FontSize="10"
                                               TextColor="{StaticResource TextTertiary}"
                                               HorizontalOptions="Center" />
                                    </VerticalStackLayout>
                                </Border>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </ScrollView>

            <!-- MUSCLES TAB -->
            <ScrollView IsVisible="{Binding IsMusclesTab}">
                <VerticalStackLayout Padding="20,16" Spacing="16">

                    <!-- Section header + range toggle -->
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="MUSCLE DISTRIBUTION"
                               FontSize="11" FontAttributes="Bold"
                               CharacterSpacing="1.5" TextColor="{StaticResource TextTertiary}"
                               VerticalOptions="Center" />
                        <Border Grid.Column="1"
                                BackgroundColor="{StaticResource Surface1}"
                                StrokeThickness="0" Padding="12,7">
                            <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding CycleMuscleRangeCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="{Binding MuscleRangeLabel}"
                                   FontSize="12" FontAttributes="Bold"
                                   TextColor="{StaticResource Accent}" />
                        </Border>
                    </Grid>

                    <!-- Horizontal bar chart -->
                    <Border BackgroundColor="{StaticResource Surface1}"
                            StrokeThickness="0" Padding="16">
                        <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                        <GraphicsView Drawable="{Binding MuscleChart}"
                                      HeightRequest="220" />
                    </Border>

                    <!-- Muscle list -->
                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding MuscleItems}" Spacing="6">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="services:MuscleVolume">
                                <Border BackgroundColor="{StaticResource Surface1}"
                                        StrokeThickness="0" Padding="14,12">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                        <VerticalStackLayout Grid.Column="0" Spacing="5">
                                            <Label Text="{Binding MuscleGroupName}"
                                                   FontSize="14" FontAttributes="Bold"
                                                   TextColor="{StaticResource TextPrimary}" />
                                        </VerticalStackLayout>
                                        <Label Grid.Column="1"
                                               FontSize="15" FontAttributes="Bold"
                                               TextColor="{StaticResource Accent}"
                                               VerticalOptions="Center">
                                            <Label.Text>
                                                <Binding Path="Fraction" StringFormat="{}{0:P0}" />
                                            </Label.Text>
                                        </Label>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                    <!-- Empty state -->
                    <VerticalStackLayout IsVisible="{Binding IsMuscleSectionEmpty}"
                                         VerticalOptions="Center" HorizontalOptions="Center"
                                         Spacing="10" Padding="0,40">
                        <Label Text="💪" FontSize="48" HorizontalOptions="Center" />
                        <Label Text="No workout data yet"
                               FontSize="18" FontAttributes="Bold"
                               TextColor="{StaticResource TextSecondary}"
                               HorizontalOptions="Center" />
                        <Label Text="Log a few sessions to see muscle distribution"
                               FontSize="13" TextColor="{StaticResource TextTertiary}"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </ScrollView>

            <!-- FREQUENCY TAB -->
            <ScrollView IsVisible="{Binding IsFrequencyTab}">
                <VerticalStackLayout Padding="20,16" Spacing="16">

                    <Label Text="SESSIONS PER WEEK" FontSize="11" FontAttributes="Bold"
                           CharacterSpacing="1.5" TextColor="{StaticResource TextTertiary}" />

                    <Border BackgroundColor="{StaticResource Surface1}"
                            StrokeThickness="0" Padding="16">
                        <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                        <GraphicsView Drawable="{Binding FrequencyChart}"
                                      HeightRequest="200" />
                    </Border>

                </VerticalStackLayout>
            </ScrollView>

        </Grid>

    </Grid>

</ContentPage>

